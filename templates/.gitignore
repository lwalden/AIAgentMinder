# ==============================================================================
# Core .gitignore -- secrets, IDE files, OS artifacts
# Stack-specific entries are added by /setup based on your tech stack.
# For comprehensive language gitignores, see: https://github.com/github/gitignore
# ==============================================================================

# Secrets and environment variables -- NEVER commit these
.env
.env.local
.env.*.local
*.env
.envrc
.secrets
secrets/
*.pem
*.key
*.p12
*.pfx
local.settings.json

# IDE and editor artifacts
.idea/
.vscode/
*.swp
*.swo
*~
.vs/
*.user
*.suo

# OS generated
.DS_Store
._*
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# MCP server config (may contain API keys — user-specific runtime state)
.mcp.json

# Local-only Claude Code settings (per-machine permissions / overrides)
.claude/settings.local.json

# AIAgentMinder context cycling (ephemeral state files)
.sprint-continuation.md
.sprint-continue-signal
.sprint-human-checkpoint
.sprint-errors.log
.context-usage
.context-usage.tmp
.corrections.jsonl
.correction-state
.sprint-metrics.json
.sprint-tool-count
.sprint-phase-guard-count

# AIAgentMinder agent worktrees (PR pipeline scratch dirs — leak on crash)
.claude/worktrees/

# Executive dispatch state (ephemeral, written by dispatch contract)
.exec/

# Quality gate marker files (written by hooks, never committed)
.quality-gate-pass
.quality-review-result.json
.tests-passed

# Python cache
__pycache__/
*.pyc

# Claude Code auto memory (project-specific, not for version control)
# Uncomment if you use Claude Code's auto memory feature:
# .claude/memory/

# Stack-specific entries added below by /setup:
